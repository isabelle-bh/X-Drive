// schema for x tronics CRM 

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model User {
    id  String @id @default(cuid())
    firstName    String
    lastName    String
    email   String @unique
    password    String ? // hashed
    isActive    Boolean @default(false) // has set password? 
    role    Role @default(USER)
    createdAt   DateTime @default(now())

    sessions        Session[]
    contacts        Contact[]
    organizations   Organization[]
    leads           Lead[]
    opportunities   Opportunity[]
}

model Invitation {
    id          String @id @default(cuid())
    email       String
    token       String @unique
    role        Role @default(USER)
    accepted    Boolean @default(false)
    expiresAt   DateTime 
}

// enum: a field that can only be one of a fixed set of values
enum Role {
    ADMIN
    USER
}

model Session {
    id          String @id
    userId      String
    user        User @relation(fields: [userId], references: [id])
    expiresAt   DateTime
}


model Contact {
    id          String @id @default(cuid())
    firstName   String
    lastName    String?
    email       String
    phone       String?
    title       String?

    organizationId  String
    organization    Organization @relation(fields: [organizationId], references: [id])

    leads           Lead[]
    opportunities   Opportunity[]

    ownerId  String
    owner    User @relation(fields: [ownerId], references: [id])
    
}

model Organization {
    id      String @id @default(cuid())
    name    String
    address String
    website String
    phone   String

    contacts        Contact[]
    opportunities   Opportunity[]

    ownerId  String
    owner    User @relation(fields: [ownerId], references: [id])
    
}

model Lead {
    id          String @id @default(cuid())
    title       String
    interest    String?

    opportunity Opportunity[]

    contactId   String
    contact     Contact @relation(fields: [contactId], references: [id])

    ownerId     String
    owner       User @relation(fields: [ownerId], references: [id])

}

model Opportunity {
    id      String @id @default(cuid())
    title   String
    value   Float?
    stage   String // will be changed to stage table later so we can reorder columns and customize pipeline nicely

    contactId   String
    contact     Contact @relation(fields: [contactId], references: [id])

    organizationId  String
    organization    Organization @relation(fields: [organizationId], references: [id])

    leadId  String
    lead    Lead @relation(fields: [leadId], references: [id])

    ownerId  String
    owner    User @relation(fields: [ownerId], references: [id])
    
}